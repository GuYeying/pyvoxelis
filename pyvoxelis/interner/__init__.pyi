    # 节点创建
    def get_or_create_leaf(self, value: int) -> BlockId: ...
    def get_or_create_branch(self, children: Children, types: int, mask: int) -> BlockId: ...
    def create_empty_branch(self) -> BlockId: ...
    def create_branch(self, children: Children, types: int, mask: int) -> BlockId: ...
    def update_branch(
        self,
        block_id: BlockId,
        child_id: BlockId,
