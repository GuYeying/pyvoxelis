    def patterns_empty(self) -> bool: ...

    # 读取与子节点
    def get_value(self, block_id: BlockId) -> int: ...
    def get_children(self, block_id: BlockId) -> Children: ...
    def get_child_id(self, block_id: BlockId, index: int) -> BlockId: ...
    def get_ref(self, block_id: BlockId) -> int: ...

    # 引用计数
