    @property
    def alive_nodes(self) -> int: ...
    @property
    def patterns(self) -> int: ...
    @property
    def total_cache_hits(self) -> int: ...
    @property
    def total_cache_misses(self) -> int: ...
    @property
    def branch_cache_hits(self) -> int: ...
    @property
    def branch_cache_misses(self) -> int: ...
    @property
    def leaf_cache_hits(self) -> int: ...
    @property
    def leaf_cache_misses(self) -> int: ...
    @property
    def collapsed_branches(self) -> int: ...
    @property
    def leaf_nodes(self) -> int: ...
    @property
    def branch_nodes(self) -> int: ...
    @property
    def max_alive_nodes(self) -> int: ...
    @property
    def max_node_id(self) -> int: ...
    @property
    def max_branch_ref_count(self) -> int: ...
    @property
    def max_leaf_ref_count(self) -> int: ...
    @property
